# MiraLingo local development config
# Copy to .env for local runs. Never commit real secrets.

MIRALINGO_ENV=development
MIRALINGO_ENABLE_LOCAL_ADMIN=true
MIRALINGO_SESSION_SECRET=replace-with-random-48-plus-char-secret
MIRALINGO_SESSION_COOKIE_NAME=miralingo_session
MIRALINGO_SESSION_TTL_SECONDS=1209600
MIRALINGO_PASSWORD_RESET_TTL_SECONDS=3600
MIRALINGO_FRONTEND_BASE_URL=http://localhost:5173
MIRALINGO_DATABASE_PATH=.miralingo/miralingo.sqlite3
MIRALINGO_ENABLE_DEV_RESET_LOGGING=true

# Docker Compose local deployment
# docker compose uses port 8080 by default and stores SQLite in the miralingo_db volume.
MIRALINGO_HTTP_PORT=8080
# For live production, set MIRALINGO_ENV=production, disable local admin,
# and replace this with a long random secret before first deploy.
# Example: openssl rand -hex 32
# MIRALINGO_ENV=production
# MIRALINGO_ENABLE_LOCAL_ADMIN=false
# MIRALINGO_SESSION_SECRET=replace-with-random-64-plus-char-secret

# Google OAuth local setup
# Google Cloud Console redirect URI must exactly match this value.
MIRALINGO_GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
MIRALINGO_GOOGLE_CLIENT_ID=
MIRALINGO_GOOGLE_CLIENT_SECRET=
